    </resultMap>

    <sql id="selectRoutePoiDetailVo">
        select t.poi_id, t.poi_name, t.poi_type, t.poi_category, t.latitude, t.longitude, t.address, t.poi_desc, t.poi_images, t.contact_phone, t.business_hours, t.rating, t.contributor_id, fk_contributorId.user_name as userName, t.data_source, t.audit_status, t.audit_by, fk_auditBy.nick_name as nickName, t.audit_time, t.audit_remark, t.visit_count, t.like_count, t.del_flag, t.create_by, t.create_time, t.update_by, t.update_time, t.remark
        from route_poi_detail t
        left join sys_user fk_contributorId on t.contributor_id = fk_contributorId.user_id
        left join sys_user fk_auditBy on t.audit_by = fk_auditBy.user_id
    </sql>

    <select id="selectRoutePoiDetailList" parameterType="RoutePoiDetail" resultMap="RoutePoiDetailResult">
        <include refid="selectRoutePoiDetailVo"/>
        <where>  
            <if test="poiName != null  and poiName != ''"> and t.poi_name like concat('%', #{poiName}, '%')</if>
            <if test="poiType != null  and poiType != ''"> and t.poi_type = #{poiType}</if>
            <if test="poiCategory != null  and poiCategory != ''"> and t.poi_category = #{poiCategory}</if>
            <if test="latitude != null "> and t.latitude = #{latitude}</if>
            <if test="longitude != null "> and t.longitude = #{longitude}</if>
            <if test="address != null  and address != ''"> and t.address = #{address}</if>
            <if test="poiDesc != null  and poiDesc != ''"> and t.poi_desc = #{poiDesc}</if>
            <if test="poiImages != null  and poiImages != ''"> and t.poi_images = #{poiImages}</if>
            <if test="contactPhone != null  and contactPhone != ''"> and t.contact_phone = #{contactPhone}</if>
            <if test="businessHours != null  and businessHours != ''"> and t.business_hours = #{businessHours}</if>
            <if test="rating != null "> and t.rating = #{rating}</if>
            <if test="contributorId != null "> and t.contributor_id = #{contributorId}</if>
            <if test="dataSource != null  and dataSource != ''"> and t.data_source = #{dataSource}</if>
            <if test="auditStatus != null  and auditStatus != ''"> and t.audit_status = #{auditStatus}</if>
            <if test="auditBy != null "> and t.audit_by = #{auditBy}</if>
            <if test="auditTime != null "> and t.audit_time = #{auditTime}</if>
            <if test="auditRemark != null  and auditRemark != ''"> and t.audit_remark = #{auditRemark}</if>
            <if test="visitCount != null "> and t.visit_count = #{visitCount}</if>
            <if test="likeCount != null "> and t.like_count = #{likeCount}</if>
        </where>
    </select>
    
    <select id="selectRoutePoiDetailByPoiId" parameterType="Long" resultMap="RoutePoiDetailResult">
        <include refid="selectRoutePoiDetailVo"/>
        where t.poi_id = #{poiId}
    </select>

