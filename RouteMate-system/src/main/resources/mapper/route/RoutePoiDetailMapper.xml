    <delete id="deleteRoutePoiDetailByPoiId" parameterType="Long">
        delete from route_poi_detail where poi_id = #{poiId}
    </delete>

    <delete id="deleteRoutePoiDetailByPoiIds" parameterType="String">
        delete from route_poi_detail where poi_id in 
        <foreach item="poiId" collection="array" open="(" separator="," close=")">
            #{poiId}
        </foreach>
    </delete>

    <!-- 查询贡献者ID（关联sys_user.user_id）（关联用户信息表）选项列表 -->
    <select id="selectContributorIdOptions" resultType="java.util.HashMap">
        select 
            user_id,
            user_name as userName
        from sys_user
        order by user_id desc
    </select>

    <!-- 查询审核人ID（关联用户信息表）选项列表 -->
    <select id="selectAuditByOptions" resultType="java.util.HashMap">
        select 
            user_id,
            nick_name as nickName
        from sys_user
